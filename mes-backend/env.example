# MES backend environment variables template
# Copy this file to `.env` and customize for your environment.

# Server
SERVER_ADDR=0.0.0.0:8080

# Database (Postgres)
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://mes_user:mes_password@localhost:5432/mes_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT secret used to sign tokens - change in production
JWT_SECRET=your-secret-key-change-in-production

# MQTT broker (used by equipment manager)
MQTT__DEFAULT_BROKER=tcp://localhost:1883

# Optional: local postgres settings (used by docker-compose example)
POSTGRES_USER=mes_user
POSTGRES_PASSWORD=mes_password
POSTGRES_DB=mes_db

# Logging level for tracing / env_logger
RUST_LOG=info


